{% extends 'base.html.twig' %}

{% block title %}Products - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4">Our Products</h1>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
        <div class="col">
            <div class="card h-100">
                {% if product.image is not null and product.image is not empty %}
                    <img src="{{ asset('images/' ~ product.image) }}" class="card-img-top" alt="{{ product.title }}">
                {% else %}
                    <img src="{{ asset('images/item.png') }}" class="card-img-top" alt="{{ product.title }}">
                {% endif %}
                
                <div class="card-body">
                    {% if product.category %}
                        <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                    {% endif %}
                    <h5 class="card-title">{{ product.title }}</h5>
                    <p class="card-text fw-bold text-success">${{ product.sellPrice }}</p>
                    <a href="{{ path('app_product_details', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}