{% extends 'base.html.twig' %}

{% block title %}Register - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="card-title mb-4">Create an Account</h2>

                    {{ form_start(form) }}
                        <div class="mb-3">
                            <label class="form-label">Email address</label>
                            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Create a password'}}) }}
                            {{ form_errors(form.plainPassword.first) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirm Password</label>
                            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirm your password'}}) }}
                            {{ form_errors(form.plainPassword.second) }}
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">Sign Up</button>
                        </div>
                    {{ form_end(form) }}

                    <div class="text-center mt-3">
                        <a href="{{ path('app_login') }}">Already have an account? Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}